# Copy this file to  mobile/.env  and fill in your real Supabase values.
# (Supabase dashboard → Project Settings → API Keys, and the Project URL is
#  https://<your-project-id>.supabase.co)
#
# EXPO_PUBLIC_* variables are inlined into the app at build time. mobile/.env is
# gitignored, so your real values never get committed.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-OR-PUBLISHABLE-KEY
