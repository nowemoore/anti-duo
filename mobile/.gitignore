# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files — never commit real keys; .env.example (placeholders) is kept
.env
.env.*
!.env.example

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# vendored shared logic (synced from ../shared + ../src/lib + ../public/content.json)
/vendor
/assets/content.json

# handwriting recognizer source cache (regenerated by scripts/gen-draw-patterns.js)
scripts/.kanjicanvas-cache/
