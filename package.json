{
  "name": "anti-duo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "dev": "concurrently -n client,server -c blue,green \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc --noEmit && vite build",
    "gen:content": "tsx scripts/gen-content.ts",
    "build:static": "npm run gen:content && tsc --noEmit && vite build --mode static",
    "preview": "vite preview",
    "preview:static": "vite preview --base /anti-duo/",
    "typecheck": "tsc --noEmit",
    "check:content": "tsx scripts/check-content.ts",
    "check:render": "tsx scripts/check-render.ts",
    "check:study": "tsx scripts/check-study.ts",
    "check:tasks": "tsx scripts/check-tasks.ts",
    "check:practice": "tsx scripts/check-practice.ts",
    "check:stats": "tsx scripts/check-stats.ts",
    "check": "tsx scripts/check-content.ts && tsx scripts/check-render.ts && tsx scripts/check-study.ts && tsx scripts/check-tasks.ts && tsx scripts/check-practice.ts && tsx scripts/check-stats.ts",
    "reset": "tsx scripts/reset-progress.ts",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^6.6.0",
    "@fortawesome/free-solid-svg-icons": "^6.6.0",
    "@fortawesome/react-fontawesome": "^0.2.2",
    "express": "^4.21.1",
    "papaparse": "^5.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.5",
    "@types/papaparse": "^5.3.15",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.0.1",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.10.0",
    "vite": "^5.4.9"
  }
}
